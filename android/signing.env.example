# Local release signing credentials for `./gradlew assembleRelease`.
#
# Usage (bash / macOS / Linux / WSL):
#
#   cp android/signing.env.example android/signing.env
#   # edit android/signing.env with your real values
#   source android/signing.env
#   (cd android && ./gradlew assembleRelease)
#
# The variables below are exactly what android/app/build.gradle reads when
# the CI env var is unset, so no changes to build.gradle are needed.
#
# `android/signing.env` is gitignored. NEVER commit it.

# Absolute or relative path (from android/app/) to your .keystore file.
export SBP_CHECKOUT_UPLOAD_STORE_FILE="boltcard.keystore"
export SBP_CHECKOUT_UPLOAD_STORE_PASSWORD="CHANGE_ME"
export SBP_CHECKOUT_UPLOAD_KEY_ALIAS="boltcard"
export SBP_CHECKOUT_UPLOAD_KEY_PASSWORD="CHANGE_ME"
