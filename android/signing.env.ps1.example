# Local release signing credentials for `./gradlew assembleRelease` on Windows.
#
# Usage (PowerShell):
#
#   Copy-Item android/signing.env.ps1.example android/signing.env.ps1
#   # edit android/signing.env.ps1 with your real values
#   . ./android/signing.env.ps1
#   cd android; ./gradlew.bat assembleRelease
#
# The variables below are exactly what android/app/build.gradle reads when
# the CI env var is unset, so no changes to build.gradle are needed.
#
# `android/signing.env.ps1` is gitignored. NEVER commit it.

$env:SBP_CHECKOUT_UPLOAD_STORE_FILE     = "boltcard.keystore"
$env:SBP_CHECKOUT_UPLOAD_STORE_PASSWORD = "CHANGE_ME"
$env:SBP_CHECKOUT_UPLOAD_KEY_ALIAS      = "boltcard"
$env:SBP_CHECKOUT_UPLOAD_KEY_PASSWORD   = "CHANGE_ME"
